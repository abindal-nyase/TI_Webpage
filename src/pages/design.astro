      const hex = scheme.vars[key];
      card.querySelector('.swatch-color').style.background = hex;
      card.querySelector('.swatch-hex').textContent = hex;
      if (scheme.brandSwatches && scheme.brandSwatches[i]) {
        card.querySelector('.swatch-name').textContent = scheme.brandSwatches[i].name;
        card.querySelector('.swatch-use').textContent = scheme.brandSwatches[i].use;
      }
    });
    const label = document.getElementById('brand-palette-label');
    if (label) label.textContent = `— ${scheme.name}`;
    // Highlight selected alt-card in Section 07
    document.querySelectorAll('.alt-card[data-palette-id]').forEach(card => {
      card.style.outline = card.dataset.paletteId === id ? '2px solid var(--color-accent)' : '';
    });
    // Swap copy text
    if (scheme.copy) {
      document.querySelectorAll('[data-copy]').forEach(el => {
        const key = el.dataset.copy;
        if (scheme.copy[key] !== undefined) el.innerHTML = scheme.copy[key];
      });
    }
    activeScheme = id;
  }

  function applyFont(id) {
    const font = FONTS.find(f => f.id === id);
    if (!font) return;
    const root = document.documentElement;
    root.style.setProperty('--font-display', font.displayFamily);
    root.style.setProperty('--font-body', font.bodyFamily);
    document.querySelectorAll('[data-font="display"]').forEach(el => el.style.fontFamily = font.displayFamily);
    document.querySelectorAll('[data-font="body"]').forEach(el => el.style.fontFamily = font.bodyFamily);
    document.querySelectorAll('.cfg-font-btn').forEach(btn =>
      btn.classList.toggle('active', btn.dataset.id === id)
    );
    // Swap font name labels in type specimens
    document.querySelectorAll('[data-font-name="display"]').forEach(el => el.textContent = font.displayLabel);
    document.querySelectorAll('[data-font-name="body"]').forEach(el => el.textContent = font.bodyLabel);
    const activeFontEl = document.getElementById('cfg-active-font');
    if (activeFontEl) activeFontEl.textContent = font.label;
    activeFont = id;
  }

  function exportCSS() {
    const scheme = SCHEMES.find(s => s.id === activeScheme);
    const font = FONTS.find(f => f.id === activeFont);
    const lines = [':root {'];
    Object.entries(scheme.vars).forEach(([k, v]) => lines.push(`  ${k}: ${v};`));
    lines.push(`  --font-display: ${font.displayFamily};`);
    lines.push(`  --font-body: ${font.bodyFamily};`);
    lines.push('}');
    navigator.clipboard.writeText(lines.join('\n')).then(() => {
      const btn = document.getElementById('cfg-export');
      btn.classList.add('copied');
      btn.innerHTML = CHECK_ICON + ' Copied!';
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.innerHTML = EXPORT_ICON + ' Export CSS';
      }, 2000);
    });
  }

  function init() {
    const colorsEl = document.getElementById('cfg-colors');
    const fontsEl = document.getElementById('cfg-fonts');

    SCHEMES.forEach(scheme => {
      const btn = document.createElement('button');
      btn.className = 'cfg-color-btn';
      btn.dataset.id = scheme.id;
      btn.title = scheme.name;
      btn.innerHTML = scheme.swatches
        .map(hex => `<span class="cfg-swatch" style="background:${hex};"></span>`)
        .join('');
      btn.addEventListener('click', () => applyScheme(scheme.id));
      colorsEl.appendChild(btn);
    });

    FONTS.forEach(font => {
      const btn = document.createElement('button');
      btn.className = 'cfg-font-btn';
      btn.dataset.id = font.id;
      btn.textContent = font.label;
      btn.addEventListener('click', () => applyFont(font.id));
      fontsEl.appendChild(btn);
    });

    document.getElementById('cfg-export').addEventListener('click', exportCSS);

    applyScheme('navy-blue');
    applyFont('playfair-inter');
  }

  window.applySchemeGlobal = applyScheme;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
