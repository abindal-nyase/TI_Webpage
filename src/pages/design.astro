      .grid-2, .grid-3, .grid-4, .grid-5 { grid-template-columns: 1fr; }
      .ds-nav { padding: 0 20px; }
    }

    /* ── Configurator panel ── */
    .cfg-panel {
      position: sticky;
      top: 52px;
      z-index: 99;
      background: rgba(10,18,35,0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 9px 32px;
    }

    .cfg-inner {
      display: flex;
      align-items: center;
      gap: 16px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .cfg-inner::-webkit-scrollbar { display: none; }

    .cfg-group {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .cfg-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .cfg-active-name {
      font-size: 11px;
      font-weight: 500;
      color: rgba(255,255,255,0.55);
      white-space: nowrap;
      min-width: 130px;
      flex-shrink: 0;
    }

    .cfg-divider {
      width: 1px;
      height: 24px;
      background: rgba(255,255,255,0.07);
      flex-shrink: 0;
    }

    .cfg-color-btn {
      display: flex;
      align-items: center;
      gap: 3px;
      padding: 5px 7px;
      border-radius: 7px;
      border: 1.5px solid transparent;
      background: rgba(255,255,255,0.04);
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      flex-shrink: 0;
    }

    .cfg-color-btn:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.15);
    }

    .cfg-color-btn.active {
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.32);
    }

    .cfg-swatch {
      width: 13px;
      height: 13px;
      border-radius: 3px;
      border: 1px solid rgba(0,0,0,0.2);
      flex-shrink: 0;
    }

    .cfg-font-btn {
      padding: 5px 11px;
      border-radius: 7px;
      border: 1.5px solid transparent;
      background: rgba(255,255,255,0.04);
      cursor: pointer;
      font-size: 11px;
      font-weight: 500;
      color: rgba(255,255,255,0.45);
      transition: border-color 0.15s, background 0.15s, color 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .cfg-font-btn:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.15);
      color: rgba(255,255,255,0.75);
    }

    .cfg-font-btn.active {
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.32);
      color: rgba(255,255,255,0.9);
    }

    .cfg-export {
      margin-left: auto;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 7px;
      background: var(--color-accent);
      color: #fff;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.03em;
      border: none;
      cursor: pointer;
      transition: filter 0.15s, transform 0.15s, background 0.2s;
    }

    .cfg-export:hover {
      filter: brightness(1.12);
      transform: translateY(-1px);
    }

    .cfg-export.copied {
      background: #059669;
    }

    @media (max-width: 640px) {
      .cfg-panel { padding: 8px 20px; }
      .cfg-active-name { display: none; }
    }
  </style>
</head>

