---
// NYA Design System Showcase
// Fonts: Playfair Display (display/headings) + Inter (body/UI)
// Blueprint: src/design/NYA_Tenant_Improvement_Figma_File_Blueprint.md
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>NYA — Design System</title>

  <!-- Font stack: Playfair Display (display/H1–H2) + Inter (body/UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&family=Spectral:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ── Design tokens (mirrors design-system.css) ── */
    :root {
      --color-primary:       #0B1F3B;
      --color-primary-light: #1E3A5F;
      --color-accent:        #2F80ED;
      --color-accent-hover:  #1C6ED5;
      --color-black:         #0F172A;
      --color-gray-900:      #1E293B;
      --color-gray-700:      #475569;
      --color-gray-500:      #64748B;
      --color-gray-300:      #E2E8F0;
      --color-gray-200:      #EEF2F7;
      --color-gray-100:      #F8FAFC;
      --color-white:         #FFFFFF;
      --color-value:         #059669;
      --border-default:      #E2E8F0;
      --border-accent:       rgba(47,128,237,0.25);
      --shadow-1: 0 1px 3px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04);
      --shadow-2: 0 4px 12px rgba(15,23,42,0.08), 0 2px 4px rgba(15,23,42,0.04);
      --shadow-3: 0 8px 24px rgba(15,23,42,0.10), 0 4px 8px rgba(15,23,42,0.06);
      --shadow-4: 0 16px 40px rgba(15,23,42,0.12), 0 8px 16px rgba(15,23,42,0.08);
      --shadow-accent: 0 8px 28px rgba(47,128,237,0.28);
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'Inter', system-ui, sans-serif;
      --font-mono:    'SF Mono', 'Fira Code', monospace;
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body);
      background: var(--color-gray-100);
      color: var(--color-black);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Sticky nav ── */
    .ds-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(11,31,59,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      gap: 0;
      height: 52px;
      padding: 0 32px;
    }

    .ds-nav-brand {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-right: 32px;
      white-space: nowrap;
    }

    .ds-nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .ds-nav-links::-webkit-scrollbar { display: none; }

    .ds-nav-links a {
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 6px;
      white-space: nowrap;
      transition: color 0.15s, background 0.15s;
    }

    .ds-nav-links a:hover {
      color: #fff;
      background: rgba(255,255,255,0.08);
    }

    .ds-nav-back {
      margin-left: auto;
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      transition: color 0.15s;
    }

    .ds-nav-back:hover { color: rgba(255,255,255,0.7); }

    /* ── Page hero ── */
    .ds-page-hero {
      background: var(--color-primary);
      padding: 80px 80px 72px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .ds-page-hero-inner {
      max-width: 860px;
    }

    .ds-page-hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--color-accent) 90%, transparent);
      margin-bottom: 24px;
    }

    .ds-page-hero-eyebrow::before {
      content: '';
      display: block;
      width: 24px;
      height: 1.5px;
      background: currentColor;
    }

    .ds-page-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: #fff;
      margin-bottom: 20px;
    }

    .ds-page-hero p {
      font-size: 16px;
      line-height: 1.65;
      color: rgba(255,255,255,0.55);
      max-width: 540px;
    }

    .ds-page-hero-meta {
      margin-top: 36px;
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }

    .ds-meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.45);
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px;
      padding: 5px 14px;
    }

    .ds-meta-pill-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-accent);
      flex-shrink: 0;
    }

    /* ── Section layout ── */
    .ds-section {
      padding: 72px 80px;
      border-bottom: 1px solid var(--border-default);
      background: var(--color-white);
    }

    .ds-section:nth-child(even) {
      background: var(--color-gray-100);
    }

    .ds-section-header {
      margin-bottom: 48px;
      display: flex;
      align-items: baseline;
      gap: 16px;
    }

    .ds-section-num {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-gray-500);
      flex-shrink: 0;
      padding-top: 2px;
    }

    .ds-section-heading {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--color-black);
    }

    /* ── Grid helpers ── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }

    /* ── Color swatches ── */
    .swatch-card {
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-white);
      border: 1px solid var(--border-default);
      box-shadow: var(--shadow-1);
      transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
    }

    .swatch-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-3);
    }

    .swatch-color { height: 80px; }

    .swatch-info { padding: 14px 16px; }

    .swatch-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--color-black);
      margin-bottom: 3px;
    }

    .swatch-hex {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-gray-500);
    }

    .swatch-use {
      font-size: 11px;
      color: var(--color-gray-500);
      margin-top: 5px;
      line-height: 1.4;
    }

    /* ── Typography specimens ── */
    .type-specimen {
      padding: 36px 0;
      border-bottom: 1px solid var(--border-default);
    }

    .type-specimen:first-child { padding-top: 0; }
    .type-specimen:last-child { border-bottom: none; padding-bottom: 0; }

    .type-meta-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .type-tag {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--color-gray-500);
      background: var(--color-gray-100);
      border: 1px solid var(--border-default);
      border-radius: 4px;
      padding: 3px 8px;
    }

    .type-tag.accent {
      background: color-mix(in srgb, var(--color-accent) 6%, transparent);
      border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
      color: var(--color-accent);
    }

    /* Type scale specimens */
    .specimen-display {
      font-family: var(--font-display);
      font-size: clamp(36px, 5vw, 64px);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--color-black);
    }

    .specimen-h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3.5vw, 44px);
      font-weight: 600;
      line-height: 1.18;
      letter-spacing: -0.01em;
      color: var(--color-black);
    }

    .specimen-h3 {
      font-family: var(--font-body);
      font-size: 20px;
      font-weight: 600;
      line-height: 1.4;
      letter-spacing: -0.01em;
      color: var(--color-black);
    }

    .specimen-body-lg {
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.65;
      font-weight: 400;
      color: var(--color-gray-700);
    }

    .specimen-body {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.65;
      font-weight: 400;
      color: var(--color-gray-700);
    }

    .specimen-label {
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.55;
      font-weight: 500;
      color: var(--color-gray-500);
    }

    .specimen-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-accent);
    }

    .specimen-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1.5px;
      background: currentColor;
    }

    /* ── Spacing bars ── */
    .space-table { display: flex; flex-direction: column; gap: 0; max-width: 640px; }

    .space-row {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border-default);
    }

    .space-row:last-child { border-bottom: none; }

    .space-token {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-gray-500);
      width: 72px;
      flex-shrink: 0;
    }

    .space-bar-track {
      width: 220px;
      height: 20px;
      background: var(--color-gray-100);
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid var(--border-default);
    }

    .space-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 30%, transparent), color-mix(in srgb, var(--color-accent) 15%, transparent));
      border-right: 2px solid var(--color-accent);
    }

    .space-px {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--color-black);
      width: 36px;
    }

    .space-note { font-size: 11px; color: var(--color-gray-500); }

    /* ── Buttons ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      height: 52px;
      padding: 0 28px;
      border-radius: var(--radius-sm);
      background: var(--color-accent);
      color: #fff;
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background 220ms var(--ease-out), transform 220ms var(--ease-out), box-shadow 220ms var(--ease-out);
    }

    .btn-primary:hover {
      background: var(--color-accent-hover);
      transform: translateY(-2px);
      box-shadow: var(--shadow-accent);
    }

    .btn-primary:disabled {
      background: var(--color-gray-300);
      color: var(--color-gray-500);
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      height: 52px;
      padding: 0 28px;
      border-radius: var(--radius-sm);
      background: transparent;
      color: var(--color-primary);
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 500;
      border: 1.5px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
      cursor: pointer;
      text-decoration: none;
      transition: border-color 220ms var(--ease-out), background 220ms var(--ease-out), transform 220ms var(--ease-out);
    }

    .btn-secondary:hover {
      border-color: var(--color-primary);
      background: color-mix(in srgb, var(--color-primary) 4%, transparent);
      transform: translateY(-1px);
    }

    .btn-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

    /* ── Cards ── */
    .feature-card {
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 28px;
      border-radius: var(--radius-lg);
      background: var(--color-white);
      border: 1px solid var(--border-default);
      box-shadow: var(--shadow-1);
      transition: transform 300ms var(--ease-out), box-shadow 300ms var(--ease-out), border-color 300ms var(--ease-out);
    }

    .feature-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-4);
      border-color: var(--border-accent);
    }

    .card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: color-mix(in srgb, var(--color-accent) 8%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-accent);
      flex-shrink: 0;
    }

    .card-title {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 600;
      color: var(--color-black);
      letter-spacing: -0.01em;
    }

    .card-body {
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.65;
      color: var(--color-gray-700);
    }

    .process-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
      padding: 28px 20px;
      border-radius: var(--radius-lg);
      background: var(--color-white);
      border: 1px solid var(--border-default);
      box-shadow: var(--shadow-1);
    }

    .step-number {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: var(--color-primary);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-body);
      font-size: 18px;
      font-weight: 600;
      flex-shrink: 0;
    }

    /* ── Radius showcase ── */
    .radius-card {
      background: var(--color-white);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      padding: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    .radius-box {
      width: 72px;
      height: 72px;
      background: color-mix(in srgb, var(--color-accent) 10%, transparent);
      border: 1.5px solid var(--color-accent);
    }

    .radius-label {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      color: var(--color-black);
      text-align: center;
    }

    .radius-value {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-gray-500);
    }

    /* ── Divider ── */
    .divider { height: 1px; background: var(--border-default); margin: 48px 0; }

    /* ── Sub-heading ── */
    .sub-heading {
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-gray-500);
      margin-bottom: 20px;
    }

    /* ── Alternates section ── */
    .alt-card {
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-default);
      background: var(--color-white);
      overflow: hidden;
      box-shadow: var(--shadow-1);
      transition: transform 250ms var(--ease-out), box-shadow 250ms var(--ease-out);
    }

    .alt-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-3);
    }

    .alt-card-badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: #fff;
      padding: 3px 10px;
      border-radius: 999px;
      display: inline-block;
    }

    .alt-card-header {
      padding: 20px 22px 16px;
      border-bottom: 1px solid var(--border-default);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .alt-card-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--color-black);
    }

    .alt-card-body { padding: 18px 22px 20px; }

    .alt-card-desc {
      font-size: 13px;
      line-height: 1.6;
      color: var(--color-gray-700);
      margin-bottom: 16px;
    }

    .alt-select-btn {
      margin-top: 14px;
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-accent);
      background: none;
      border: 1px solid var(--color-accent);
      border-radius: 6px;
      padding: 5px 12px;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .alt-select-btn:hover {
      background: var(--color-accent);
      color: #fff;
    }

    .mini-swatches { display: flex; gap: 6px; }

    .mini-swatch {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid rgba(0,0,0,0.08);
    }

    /* Font alt cards */
    .font-alt-card {
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-default);
      background: var(--color-white);
      box-shadow: var(--shadow-1);
      overflow: hidden;
      transition: transform 250ms var(--ease-out), box-shadow 250ms var(--ease-out);
    }

    .font-alt-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-3);
    }

    .font-alt-header {
      padding: 16px 22px;
      background: var(--color-gray-100);
      border-bottom: 1px solid var(--border-default);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .font-alt-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-gray-500);
    }

    .font-alt-names {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--color-gray-500);
    }

    .font-alt-body { padding: 22px 22px 24px; }

    .font-alt-specimen {
      margin-bottom: 10px;
      color: var(--color-black);
    }

    .font-alt-desc {
      font-size: 12px;
      line-height: 1.6;
      color: var(--color-gray-500);
      margin-top: 12px;
    }

    /* Button variants */
    .btn-variant-row {
      padding: 24px 28px;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-default);
      background: var(--color-white);
    }

    .btn-variant-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-gray-500);
      margin-bottom: 16px;
    }

    /* ── Section previews ── */
    .preview-wrap {
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid var(--border-default);
      box-shadow: var(--shadow-2);
      margin-bottom: 36px;
    }

    .preview-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-gray-500);
      margin-bottom: 14px;
    }

    @media (max-width: 960px) {
      .ds-page-hero { padding: 56px 40px 48px; }
      .ds-section { padding: 56px 40px; }
      .grid-3, .grid-4, .grid-5 { grid-template-columns: 1fr 1fr; }
