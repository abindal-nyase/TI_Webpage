<section class="ds-section" id="typography">
  <div class="ds-section-header">
    <span class="ds-section-num">02</span>
    <h2 class="ds-section-heading">Typography</h2>
  </div>

  <!-- Font stack callout -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:48px;">
    <div class="js-accent-bg-subtle" style="padding:24px 28px; border-radius:var(--radius-lg); border:1px solid var(--border-accent); background:rgba(47,128,237,0.03);">
      <p style="font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-accent); margin-bottom:10px;">Display &amp; Headings</p>
      <p data-font="display" data-font-name="display" style="font-family:var(--font-display); font-size:28px; font-weight:700; color:var(--color-black); letter-spacing:-0.01em; margin-bottom:8px;">Playfair Display</p>
      <p style="font-size:13px; color:var(--color-gray-500); line-height:1.6;">Serif typeface for H1–H2 headlines. Brings editorial authority and warmth to structural messaging. Weights 400–700.</p>
      <div style="display:flex; gap:12px; margin-top:14px;">
        <span data-font="display" style="font-family:var(--font-display); font-size:16px; font-weight:400; color:var(--color-gray-700);">Regular</span>
        <span data-font="display" style="font-family:var(--font-display); font-size:16px; font-weight:600; color:var(--color-gray-700);">SemiBold</span>
        <span data-font="display" style="font-family:var(--font-display); font-size:16px; font-weight:700; color:var(--color-gray-700);">Bold</span>
        <span data-font="display" style="font-family:var(--font-display); font-size:16px; font-weight:600; font-style:italic; color:var(--color-gray-700);">Italic</span>
      </div>
    </div>
    <div style="padding:24px 28px; border-radius:var(--radius-lg); border:1px solid var(--border-default); background:var(--color-gray-100);">
      <p style="font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-gray-500); margin-bottom:10px;">Body &amp; UI</p>
      <p data-font="body" data-font-name="body" style="font-family:var(--font-body); font-size:28px; font-weight:600; color:var(--color-black); letter-spacing:-0.02em; margin-bottom:8px;">Inter</p>
      <p style="font-size:13px; color:var(--color-gray-500); line-height:1.6;">Geometric sans-serif for H3, body, labels, and all UI elements. Exceptional readability at every size. Weights 300–700.</p>
      <div style="display:flex; gap:12px; margin-top:14px;">
        <span data-font="body" style="font-family:var(--font-body); font-size:16px; font-weight:300; color:var(--color-gray-700);">Light</span>
        <span data-font="body" style="font-family:var(--font-body); font-size:16px; font-weight:400; color:var(--color-gray-700);">Regular</span>
        <span data-font="body" style="font-family:var(--font-body); font-size:16px; font-weight:500; color:var(--color-gray-700);">Medium</span>
        <span data-font="body" style="font-family:var(--font-body); font-size:16px; font-weight:600; color:var(--color-gray-700);">SemiBold</span>
        <span data-font="body" style="font-family:var(--font-body); font-size:16px; font-weight:700; color:var(--color-gray-700);">Bold</span>
      </div>
    </div>
  </div>

  <!-- Eyebrow -->
  <div class="type-specimen">
    <span class="specimen-eyebrow" data-copy="eyebrow">Tenant Improvement</span>
    <div class="type-meta-row">
      <span class="type-tag accent">Caps / Eyebrow</span>
      <span class="type-tag" data-font-name="body">Inter</span>
      <span class="type-tag">11px / 16px</span>
      <span class="type-tag">700 Bold</span>
      <span class="type-tag">0.10em tracking</span>
      <span class="type-tag" data-copy="accentLabel">Accent Blue — section labels</span>
    </div>
  </div>

  <!-- H1 -->
  <div class="type-specimen">
    <p class="specimen-display" data-copy="h1">Most engineers see the space.<br/>We see how the building actually works.</p>
    <div class="type-meta-row">
      <span class="type-tag accent">H1 / Hero</span>
      <span class="type-tag" data-font-name="display">Playfair Display</span>
      <span class="type-tag">64px / 72px</span>
      <span class="type-tag">700 Bold</span>
      <span class="type-tag">−0.02em tracking</span>
      <span class="type-tag">color-black — hero headline</span>
    </div>
  </div>

  <!-- H2 -->
  <div class="type-specimen">
    <p class="specimen-h2" data-copy="h2">What Looks Simple Can Become Complicated Quickly</p>
    <div class="type-meta-row">
      <span class="type-tag accent">H2 / Section</span>
      <span class="type-tag" data-font-name="display">Playfair Display</span>
      <span class="type-tag">44px / 52px</span>
      <span class="type-tag">600 SemiBold</span>
      <span class="type-tag">−0.01em tracking</span>
      <span class="type-tag">color-black — section headlines</span>
    </div>
  </div>

  <!-- H3 -->
  <div class="type-specimen">
    <p class="specimen-h3" data-copy="h3">A Firm Built on Care, Trust, and Serious Work</p>
    <div class="type-meta-row">
      <span class="type-tag accent">H3 / Card</span>
      <span class="type-tag" data-font-name="body">Inter</span>
      <span class="type-tag">20px / 28px</span>
      <span class="type-tag">600 SemiBold</span>
      <span class="type-tag">−0.01em tracking</span>
      <span class="type-tag">color-black — card titles</span>
    </div>
  </div>

  <!-- Body Large -->
  <div class="type-specimen">
    <p class="specimen-body-lg" data-copy="bodyLg">Tenant improvements succeed when the existing building is understood, not assumed. NYA brings clarity to structure, constraints, and possibilities before decisions become costly.</p>
    <div class="type-meta-row">
      <span class="type-tag accent">Body / Large</span>
      <span class="type-tag" data-font-name="body">Inter</span>
      <span class="type-tag">18px / 28px</span>
      <span class="type-tag">400 Regular</span>
      <span class="type-tag">1.65 line-height</span>
      <span class="type-tag">gray-700 — hero &amp; section intros</span>
    </div>
  </div>

  <!-- Body Default -->
  <div class="type-specimen">
    <p class="specimen-body" data-copy="body">Existing buildings rarely behave like clean templates. Years of prior modifications, hidden as-built discrepancies, and on-site adaptations mean the real condition is always particular. NYA tailors details to reduce field conflicts and construction-phase surprises.</p>
    <div class="type-meta-row">
      <span class="type-tag accent">Body / Default</span>
      <span class="type-tag" data-font-name="body">Inter</span>
      <span class="type-tag">16px / 26px</span>
      <span class="type-tag">400 Regular</span>
      <span class="type-tag">1.65 line-height</span>
      <span class="type-tag">gray-700 — standard text</span>
    </div>
  </div>

  <!-- Label -->
  <div class="type-specimen">
    <p class="specimen-label">Structural clarity before costly decisions.</p>
    <div class="type-meta-row">
      <span class="type-tag accent">Label / Small</span>
      <span class="type-tag">Inter</span>
      <span class="type-tag">14px / 22px</span>
      <span class="type-tag">500 Medium</span>
      <span class="type-tag">gray-500 — notes, captions</span>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════
     03 — Spacing
════════════════════════════════ -->
<section class="ds-section" id="spacing">
  <div class="ds-section-header">
    <span class="ds-section-num">03</span>
    <h2 class="ds-section-heading">Spacing Scale</h2>
  </div>

  <div class="grid-2" style="gap:48px;">
    <div>
      <p class="sub-heading">4px Base Scale</p>
      <div class="space-table">
        {[
          { token: '--sp-1',  px: 4,   note: 'Micro gap' },
          { token: '--sp-2',  px: 8,   note: 'Tight gap' },
          { token: '--sp-3',  px: 12,  note: 'Close items' },
          { token: '--sp-4',  px: 16,  note: 'Default gap' },
          { token: '--sp-5',  px: 20,  note: '' },
          { token: '--sp-6',  px: 24,  note: 'Card internal' },
          { token: '--sp-7',  px: 28,  note: '' },
          { token: '--sp-8',  px: 32,  note: 'Card padding' },
          { token: '--sp-10', px: 40,  note: '' },
          { token: '--sp-12', px: 48,  note: 'Section sub-gap' },
          { token: '--sp-16', px: 64,  note: 'Mobile section pad' },
          { token: '--sp-18', px: 72,  note: '' },
          { token: '--sp-20', px: 80,  note: '' },
          { token: '--sp-30', px: 120, note: 'Desktop section pad' },
        ].map(({ token, px, note }) => (
          <div class="space-row">
            <span class="space-token">{token}</span>
            <div class="space-bar-track">
              <div class="space-bar-fill" style={`width:${Math.min((px / 120) * 100, 100)}%`}></div>
            </div>
            <span class="space-px">{px}px</span>
            <span class="space-note">{note}</span>
          </div>
        ))}
      </div>
    </div>

    <div>
      <p class="sub-heading">Layout Tokens</p>
      <div class="space-table">
        {[
          { token: '--container',        value: '1200px',  note: 'Max content width' },
          { token: '--container-narrow', value: '780px',   note: 'Narrow text column' },
          { token: '--section-padding',  value: '120px',   note: 'Desktop vert. padding' },
          { token: '--section-mob',      value: '64px',    note: 'Mobile vert. padding' },
          { token: '--gutter',           value: '32px',    note: 'Column gutter' },
          { token: '--margin-desktop',   value: '120px',   note: 'Side margins @ 1440' },
        ].map(({ token, value, note }) => (
          <div class="space-row">
            <span class="space-token" style="width:180px;">{token}</span>
            <span class="space-px" style="width:64px;">{value}</span>
            <span class="space-note">{note}</span>
          </div>
        ))}
      </div>

      <div class="divider" style="margin:36px 0;"></div>

      <p class="sub-heading">Grid System</p>
      <div style="display:flex; flex-direction:column; gap:12px; margin-top:4px;">
        {[
          { label: 'Desktop frame',  value: '1440px' },
          { label: 'Columns',        value: '12' },
          { label: 'Gutter',         value: '32px' },
          { label: 'Margin (each)',  value: '120px' },
        ].map(({ label, value }) => (
          <div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--border-default); align-items:center;">
            <span style="font-size:13px; color:var(--color-gray-700);">{label}</span>
            <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; color:var(--color-black);">{value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

