---
import '../index.css'
import GlobalSetup from '../components/GlobalSetup/GlobalSetup'
import AudienceCards from '../components/AudienceCards/AudienceCards'
import AudienceSwitcher from '../components/ti-option2/AudienceSwitcher'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>NYA TI — Audience Options</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; background: #0d0d0d; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
      .dev-bar {
        position: sticky;
        top: 0;
        z-index: 9999;
        background: #0d0d0d;
        border-bottom: 1px solid #222;
        padding: 12px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .dev-bar a { color: #4a7fe0; font-size: 13px; text-decoration: none; }
      .dev-bar a:hover { text-decoration: underline; }
      .dev-bar .title { color: #888; font-size: 13px; }
      .dev-bar .sep { color: #333; }
      .option-label {
        background: #111;
        border-top: 1px solid #1e1e1e;
        border-bottom: 1px solid #1e1e1e;
        padding: 10px 24px;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #555;
      }
    </style>
  </head>
  <body>
    <GlobalSetup client:load />

    <div class="dev-bar">
      <a href="/">← Dev Hub</a>
      <span class="sep">|</span>
      <span class="title">Audience — Component Options</span>
    </div>

    <div class="option-label">Option 1 — Audience Cards (current)</div>
    <AudienceCards client:load />

    <div class="option-label">Option 2 — Audience Switcher</div>
    <AudienceSwitcher client:load />
  </body>
</html>
